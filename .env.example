# ==========================================
# FRONTEND CONFIGURATION (Vite Client)
# ==========================================
# Lokasi: File `.env` di root project Anda saat build / development lokal
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_ICP_CANISTER_ID=ryjl3-tyaaa-aaaaa-aaaba-cai

# ==========================================
# BACKEND CONFIGURATION (Supabase Secrets)
# ==========================================
# Variabel berikut harus diset sebagai Secrets di Supabase console
# atau menggunakan CLI: `supabase secrets set KEY=VALUE`
#
# 1. AI Integration
GROQ_API_KEY=gsk_your_groq_api_key

# 2. Blockchain & Identity
ICP_CANISTER_ID=ryjl3-tyaaa-aaaaa-aaaba-cai
ICP_IDENTITY_PEM=your_base64_encoded_pem_private_key
ICP_HOST=https://ic0.app
PSEUDONYMOUS_SALT=your_secure_random_salt_for_pseudonyms
